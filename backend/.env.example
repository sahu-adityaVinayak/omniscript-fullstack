DATABASE_URL=sqlite:///./omniscript.db
JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REFRESH_COOKIE_NAME=omni_refresh_token
SECURE_COOKIES=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
OTP_EXPIRE_MINUTES=10
DEV_RETURN_OTP=true

# SMTP (configure these in production to email OTP codes)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# OpenAI-compatible provider (used for real AI outputs)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
